<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

    </data>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/default_bg_color"
        tools:context=".setting.SettingActivity">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/layout_container_all"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/tv_parse_raw_match_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="30dp"
                android:gravity="center"
                android:text="粘贴输入原始文本"
                android:textColor="@color/black"
                android:textSize="16dp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <!--            文本格式调整-->
            <EditText
                android:id="@+id/et_text_format_trans"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_marginTop="10dp"
                android:layout_marginEnd="10dp"
                android:padding="12dp"
                android:background="@drawable/bg_edit_text_border"
                android:gravity="center"
                android:hint="文本原始文本，调整至规范格式"
                android:lines="4"
                android:maxLines="3"
                android:textColor="@color/black"
                android:textSize="14dp"
                app:layout_constraintTop_toBottomOf="@id/tv_parse_raw_match_text" />

            <TextView
                android:id="@+id/tv_trans_raw_match_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="15dp"
                android:gravity="center"
                android:text="调整文本格式"
                android:textColor="@color/black"
                android:textSize="16dp"
                android:textStyle="bold"
                app:layout_constraintEnd_toStartOf="@id/tv_input_match_score"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/et_text_format_trans" />

            <TextView
                android:id="@+id/tv_input_match_score"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="弹窗输入分数"
                android:textColor="@color/black"
                android:textSize="16dp"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="@id/tv_trans_raw_match_text"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/tv_trans_raw_match_text"
                app:layout_constraintTop_toTopOf="@id/tv_trans_raw_match_text" />

            <TextView
                android:id="@+id/tv_input_tips"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="30dp"
                android:gravity="center"
                android:text="输入赛程"
                android:textColor="@color/black"
                android:textSize="16dp"
                app:layout_constraintEnd_toStartOf="@id/tv_input_parse"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tv_input_match_score" />

            <TextView
                android:id="@+id/tv_input_parse"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="粘贴插入赛程"
                android:textColor="@color/black"
                android:textSize="16dp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/tv_input_tips"
                app:layout_constraintTop_toTopOf="@id/tv_input_tips" />


            <EditText
                android:id="@+id/et_match_input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_marginTop="10dp"
                android:layout_marginEnd="10dp"
                android:background="@drawable/bg_edit_text_border"
                android:gravity="center"
                android:hint="不同赛程间用空一行，同一赛程每个名字单独一行"
                android:lines="4"
                android:textColor="@color/black"
                android:textSize="14dp"
                android:padding="12dp"
                app:layout_constraintTop_toBottomOf="@id/tv_input_tips" />

            <!--    一键生成所有问题    -->

            <TextView
                android:id="@+id/tv_combine_all_question"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="30dp"
                android:layout_marginEnd="10dp"
                android:gravity="center"
                android:text="生成问题集合"
                android:textColor="@color/black"
                android:textSize="16dp"
                android:textStyle="bold"
                app:layout_constraintEnd_toStartOf="@id/tv_copy_question"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/et_match_input" />

            <TextView
                android:id="@+id/tv_copy_question"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:gravity="center"
                android:text="复制提问"
                android:textColor="@color/black"
                android:textSize="16dp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/tv_combine_all_question"
                app:layout_constraintTop_toTopOf="@+id/tv_combine_all_question" />

            <EditText
                android:id="@+id/et_final_question"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_marginTop="10dp"
                android:layout_marginEnd="10dp"
                android:background="@drawable/bg_edit_text_border"
                android:gravity="center"
                android:hint="一键生成所有问题的组合"
                android:padding="12dp"
                android:lines="4"
                android:textColor="@color/black"
                android:textSize="14dp"
                app:layout_constraintTop_toBottomOf="@id/tv_combine_all_question" />

            <TextView
                android:id="@+id/tv_split_to_single_match"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_marginTop="30dp"
                android:layout_marginEnd="10dp"
                android:gravity="center"
                android:text="选择单场比赛"
                android:textColor="@color/black"
                android:textSize="16dp"
                android:textStyle="bold"
                app:layout_constraintTop_toBottomOf="@id/et_final_question" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>
</layout>