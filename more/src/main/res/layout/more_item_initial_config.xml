<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>

    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginStart="10dp"
        android:layout_marginEnd="10dp"
        android:background="@drawable/bg_any_view_border_radius"
        android:layout_marginTop="10dp"
        >

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="50dp"
            android:id="@+id/tv_title"
            android:text="球型|关型"
            android:textColor="@color/global_text_color"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />


        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="120dp"
            android:id="@+id/layout_tips_container"
            app:layout_constraintTop_toTopOf="@id/layout_answer_container"
            app:layout_constraintBottom_toBottomOf="@id/layout_answer_container"
            app:layout_constraintEnd_toStartOf="@id/layout_answer_container"
            android:layout_marginEnd="30dp"
            android:orientation="vertical"
            >
            <TextView
                android:id="@+id/tv_tips_post"
                android:layout_width="wrap_content"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:text="是否发文:"
                android:gravity="center"
                android:textColor="@color/global_text_color"
                />


            <TextView
                android:id="@+id/tv_tips_freee"
                android:layout_width="wrap_content"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:text="是否收费:"
                android:gravity="center"
                android:textColor="@color/global_text_color"
                />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:id="@+id/tv_tips_times"
                android:text="发文次数:"
                android:gravity="center"
                android:textColor="@color/global_text_color"
                />

        </LinearLayout>


        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="120dp"
            android:id="@+id/layout_answer_container"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="10dp"
            android:layout_marginEnd="30dp"
            android:orientation="vertical"
            app:layout_constraintEnd_toEndOf="parent"
            >

            <TextView
                android:id="@+id/tv_is_post"
                android:layout_width="40dp"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:padding="10dp"
                android:text="否"
                android:textColor="#999999"/>

            <TextView
                android:id="@+id/tv_is_free"
                android:layout_width="40dp"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:padding="10dp"
                android:text="否"
                android:textColor="#999999" />

            <EditText
                android:id="@+id/et_post_times"
                android:layout_width="40dp"
                android:layout_height="wrap_content"
                android:background="@null"
                android:padding="8dp"
                android:text="0"
                android:gravity="center"
                android:minEms="1"
                android:textColor="#999999"
                android:textSize="16dp"
                />

        </LinearLayout>


    </androidx.constraintlayout.widget.ConstraintLayout>

</layout>